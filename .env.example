# Lanka Platform — copy to .env.local for local dev; set in Vercel for production.

# Site URL for SSR (optional — Vercel auto-detects production URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Protect /api/cron/sync (recommended in production)
CRON_SECRET=

# Persistent sync status across cold starts
BLOB_READ_WRITE_TOKEN=

# Fast catalog search (optional — keyword fallback if unset)
MEILISEARCH_URL=
MEILISEARCH_API_KEY=

# LLM synthesis for legal + RAG (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cursor catalog agent (optional)
CURSOR_API_KEY=
ADMIN_SECRET=
